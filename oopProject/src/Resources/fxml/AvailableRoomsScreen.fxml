<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="600.0" prefWidth="800.0" styleClass="root" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hotel.controllers.AvailableRoomsController">

    <stylesheets>
        <URL value="@styles.css" />
    </stylesheets>

    <!-- ── TOP: Header ── -->
    <top>
        <VBox alignment="CENTER" style="-fx-background-color: #2c2c2c;">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <Label alignment="CENTER" maxWidth="1.7976931348623157E308" style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;" text="Available Rooms" />
                <Label fx:id="summaryLabel" alignment="CENTER" maxWidth="1.7976931348623157E308" style="-fx-text-fill: #bdc3c7; -fx-font-size: 13px;" text="Select your preferred room and amenities" />
            </children>
        </VBox>
    </top>


    <center>
        <HBox spacing="20.0">
            <padding>
                <Insets bottom="24.0" left="30.0" right="30.0" top="24.0" />
            </padding>
            <children>

                <!-- Rooms -->
                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label style="-fx-font-size: 14px;" styleClass="field-label" text="Select a Room" />
                        <Separator />
                        <ListView fx:id="roomListView" prefHeight="320.0" VBox.vgrow="ALWAYS" />
                    </children>
                </VBox>


                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label style="-fx-font-size: 14px;" styleClass="field-label" text="Select Amenities (optional)" />
                        <Separator />
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #95a5a6;" text="Hold Ctrl to select multiple" />
                        <ListView fx:id="amenityListView" prefHeight="300.0" VBox.vgrow="ALWAYS" />
                    </children>
                </VBox>

            </children>
        </HBox>
    </center>

    
    <bottom>
        <VBox style="-fx-background-color: #ecf0f1; -fx-border-color: #bdc3c7; -fx-border-width: 1 0 0 0;">
            <padding>
                <Insets bottom="14.0" left="30.0" right="30.0" top="14.0" />
            </padding>
            <children>

                <Label fx:id="statusLabel" alignment="CENTER" maxWidth="1.7976931348623157E308" styleClass="status-label" text="" />

                <HBox alignment="CENTER" spacing="20.0">
                    <children>
                        <Button onAction="#handleBack" prefHeight="38.0" prefWidth="180.0" styleClass="btn-secondary" text="← Back" />
                        <Button onAction="#handleConfirm" prefHeight="38.0" prefWidth="220.0" styleClass="btn-main" text="Confirm Reservation" />
                    </children>
                </HBox>

                <Region prefHeight="6.0" />

                <HBox alignment="CENTER_RIGHT">
                    <children>
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;" text="Logged in as: " />
                        <Label fx:id="guestTagLabel" style="-fx-font-size: 11px; -fx-text-fill: #e06d67; -fx-font-weight: bold;" text="—" />
                    </children>
                </HBox>

            </children>
        </VBox>
    </bottom>

</BorderPane>
