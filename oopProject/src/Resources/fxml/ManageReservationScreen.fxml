<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.text.Font?>


<BorderPane fx:id="WelcomeLabel" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hotel.controllers.GuestManageReservationController">
   <top>
      <HBox alignment="CENTER_LEFT" style="-fx-background-color: #e06d67;">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
         <children>
            
            <Region HBox.hgrow="ALWAYS" />

            <VBox alignment="CENTER" spacing="4.0">
               <children>
                  <Label alignment="CENTER" contentDisplay="CENTER" prefHeight="40.0" prefWidth="683.0" style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;" text="           Manage Reservations" />
                  <Label style="-fx-text-fill: #bdc3c7; -fx-font-size: 13px;" />
               </children>
            </VBox>

            <Region HBox.hgrow="ALWAYS" />

            <!-- Guest tag top-right -->
            <VBox alignment="CENTER_RIGHT" prefHeight="63.0" prefWidth="107.0" spacing="2.0">
               <children>
                  <Label style="-fx-font-size: 11px; -fx-text-fill: #aaaaaa;" text="Logged in as:" />
                  <Label fx:id="guestTagLabel" style="-fx-font-size: 14px; -fx-text-fill: #e06d67; -fx-font-weight: bold;" text="—" />
               </children>
            </VBox>

         </children>
      </HBox>
   </top>
   <center>
      <VBox maxWidth="1.7976931348623157E308" prefHeight="200.0" prefWidth="160.0" spacing="12.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
         <children>
            <Label alignment="CENTER" contentDisplay="CENTER" maxWidth="1.7976931348623157E308" text="Your Reservation History" textAlignment="CENTER">
               <font>
                  <Font size="24.0" />
               </font>
            </Label>
            <TableView fx:id="ReservationsTable" prefHeight="378.0" prefWidth="760.0" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colId" prefWidth="69.33334541320801" text="ID" />
                <TableColumn fx:id="colRoom" prefWidth="129.33330535888672" text="Room Number" />
                  <TableColumn fx:id="colType" prefWidth="121.33332824707031" text="Room Type" />
                  <TableColumn fx:id="colCheckin" prefWidth="134.66668701171875" text="Check In Date" />
                  <TableColumn fx:id="colCheckout" prefWidth="141.99990844726562" text="Check Out Date" />
                  <TableColumn fx:id="colStatus" prefWidth="159.3333740234375" text="Resrervation Status" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
            <HBox maxWidth="1.7976931348623157E308" prefHeight="100.0" prefWidth="200.0" spacing="16.0" style="-fx-background-color: #ecf0f1;">
               <padding>
                  <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
               </padding>
               <children>
                  <Button fx:id="backButton" mnemonicParsing="false" onAction="#handleBack" prefHeight="38.0" prefWidth="160.0" styleClass="btn-secondary" stylesheets="@styles.css" text="← Main Menu" />
                  <Button fx:id="makeReservationButton" layoutX="25.0" layoutY="25.0" mnemonicParsing="false" onAction="#handleMakeReservation" prefHeight="38.0" prefWidth="200.0" styleClass="btn-main" stylesheets="@styles.css" text="Make Reservation" />
                  <Button fx:id="cancelReservationButton" layoutX="201.0" layoutY="25.0" mnemonicParsing="false" onAction="#handleGoToCancel" prefHeight="38.0" prefWidth="200.0" styleClass="btn-main" stylesheets="@styles.css" text="Cancel Reservation" />
                  <Button fx:id="checkoutButton" mnemonicParsing="false" onAction="#handleCheckout" prefHeight="41.0" prefWidth="172.0" styleClass="btn-main" stylesheets="@styles.css" text="Check Out" />
               </children>
            </HBox>
         </children>
      </VBox>
   </center>
</BorderPane>
