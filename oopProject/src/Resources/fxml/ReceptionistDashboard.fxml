<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="650.0" prefWidth="900.0" style="-fx-background-color: #f0f4f8;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hotel.controllers.ReceptionistDashboardController">

    <stylesheets>
        <URL value="@styles.css" />
    </stylesheets>

    <!-- ══════════════════ TOP HEADER ══════════════════ -->
    <top>
        <VBox style="-fx-background-color: #e06d67;" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="16.0" left="24.0" right="24.0" top="16.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <children>
                        <VBox spacing="2.0">
                            <children>
                                <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;" text="🏨  Receptionist Dashboard" />
                                <Label style="-fx-font-size: 12px; -fx-text-fill: #aaaaaa;" text="HMS Hotel Management System" />
                            </children>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS" />

                        <VBox alignment="CENTER_RIGHT" spacing="2.0">
                            <children>
                                <Label style="-fx-font-size: 11px; -fx-text-fill: #aaaaaa;" text="Logged in as:" />
                                <Label fx:id="lblReceptionist" style="-fx-font-size: 14px; -fx-text-fill: #e06d67; -fx-font-weight: bold;" text="—" />
                            </children>
                        </VBox>

                        <Button onAction="#handleLogout" prefHeight="34.0" styleClass="btn-main" stylesheets="@styles.css" text="Logout" textFill="#220808" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>

    <!-- ══════════════════ LEFT SIDEBAR — Actions ══════════════════ -->
    <left>
        <VBox prefWidth="210.0" spacing="10.0" style="-fx-background-color: white;                      -fx-border-color: #e0e0e0;                      -fx-border-width: 0 1 0 0;">
            <padding>
                <Insets bottom="24.0" left="16.0" right="16.0" top="24.0" />
            </padding>
            <children>

                <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #aaaaaa;" text="ACTIONS" />
                <Separator />

                <Button maxWidth="Infinity" onAction="#handleViewAll" prefHeight="38.0" styleClass="btn-secondary" text="📋  All Reservations" />

                <Button maxWidth="Infinity" onAction="#handleViewPending" prefHeight="38.0" styleClass="btn-secondary" text="⏳  Pending Reservations" />

                <Button maxWidth="Infinity" onAction="#handleConfirm" prefHeight="38.0" styleClass="btn-main" text="✅  Confirm Reservation" />

                <Button maxWidth="Infinity" onAction="#handleCancel" prefHeight="38.0" styleClass="btn-secondary" text="❌  Cancel Reservation" />

                <Separator />

                <Button maxWidth="Infinity" onAction="#handleCheckIn" prefHeight="38.0" styleClass="btn-main" text="🛎  Check In Guest" />

                <Button maxWidth="Infinity" onAction="#handleCheckout" prefHeight="38.0" styleClass="btn-main" text="🚪  Process Checkout" />

                <!-- New Button Added Here -->
                <Button maxWidth="Infinity" onAction="#handleCompleteReservation" prefHeight="38.0" style="-fx-background-color: #27ae60; -fx-text-fill: white;" styleClass="btn-main" text="✅ Complete Reservation" />

                <Separator />

                <Button maxWidth="Infinity" onAction="#handleViewGuests" prefHeight="38.0" styleClass="btn-secondary" text="👥  View All Guests" />

                <Button maxWidth="Infinity" onAction="#handleViewRooms" prefHeight="38.0" styleClass="btn-secondary" text="🏠  View All Rooms" />

            </children>
        </VBox>
    </left>

    <!-- ══════════════════ CENTER — Main content ══════════════════ -->
    <center>
        <VBox spacing="14.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>

                <!-- ── Input row ── -->
                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <children>
                        <VBox spacing="4.0">
                            <children>
                                <Label styleClass="field-label" text="Reservation ID" />
                                <TextField fx:id="reservationIdField" prefWidth="130.0" promptText="e.g. 5" styleClass="input-field" />
                            </children>
                        </VBox>

                        <VBox spacing="4.0">
                            <children>
                                <Label styleClass="field-label" text="Guest Username" />
                                <TextField fx:id="guestUsernameField" prefWidth="200.0" promptText="e.g. ali_hassan_3" styleClass="input-field" />
                            </children>
                        </VBox>

                        <VBox spacing="4.0">
                            <children>
                                <Label styleClass="field-label" text="Room Number" />
                                <TextField fx:id="roomNumberField" prefWidth="130.0" promptText="e.g. 105" styleClass="input-field" />
                            </children>
                        </VBox>

                        <VBox spacing="4.0">
                            <children>
                                <Label styleClass="field-label" text="Payment Method" />
                                <ComboBox fx:id="paymentCombo" prefWidth="150.0" promptText="Select method" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <!-- ── Status message ── -->
                <Label fx:id="statusLabel" maxWidth="Infinity" style="-fx-font-size: 13px; -fx-text-fill: #e74c3c;" text="" wrapText="true" />

                <Separator />

                <!-- ── Reservations table ── -->
                <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #2c2c2c;" text="Reservations" />

                <TableView fx:id="reservationsTable" style="-fx-border-color: #e0e0e0; -fx-border-radius: 6; -fx-background-radius: 6;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colID" prefWidth="55.0" text="ID" />
                        <TableColumn fx:id="colGuest" prefWidth="150.0" text="Guest" />
                        <TableColumn fx:id="colRoom" prefWidth="70.0" text="Room" />
                        <TableColumn fx:id="colCheckin" prefWidth="105.0" text="Check-In" />
                        <TableColumn fx:id="colCheckout" prefWidth="105.0" text="Check-Out" />
                        <TableColumn fx:id="colStatus" prefWidth="120.0" text="Status" />
                        <TableColumn fx:id="colTotal" prefWidth="90.0" text="Total ($)" />
                    </columns>
                </TableView>

            </children>
        </VBox>
    </center>

</BorderPane>
