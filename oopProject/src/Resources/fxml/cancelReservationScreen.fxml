<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="600.0" prefWidth="850.0" styleClass="root" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hotel.controllers.CancelReservationController">

    <stylesheets>
        <URL value="@styles.css" />
    </stylesheets>

    <!-- ── TOP: Header ── -->
    <top>
        <VBox alignment="CENTER" style="-fx-background-color: #e06d67;">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <Label alignment="CENTER" maxWidth="1.7976931348623157E308" style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;" text="Cancel a Reservation" />
                <Label fx:id="welcomeLabel" alignment="CENTER" maxWidth="1.7976931348623157E308" style="-fx-text-fill: #bdc3c7; -fx-font-size: 13px;" text="Select a reservation below to cancel it" />
            </children>
        </VBox>
    </top>

    <!-- ── CENTER: Table ── -->
    <center>
        <VBox spacing="14.0">
            <padding>
                <Insets bottom="20.0" left="24.0" right="24.0" top="24.0" />
            </padding>
            <children>

                <Label style="-fx-font-size: 14px;" styleClass="field-label" text="Active Reservations" />
                <Separator />

                <TableView fx:id="cancelTable" style="-fx-border-color: #e0e0e0; -fx-border-radius: 6; -fx-background-radius: 6;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="66.0" text="ID" />
                        <TableColumn fx:id="colRoom" prefWidth="131.33331298828125" text="Room" />
                        <TableColumn fx:id="colType" prefWidth="132.66668701171875" text="Type" />
                        <TableColumn fx:id="colCheckin" prefWidth="156.0" text="Check-In" />
                        <TableColumn fx:id="colCheckout" prefWidth="156.6666259765625" text="Check-Out" />
                        <TableColumn fx:id="colStatus" prefWidth="150.00006103515625" text="Status" />
                    </columns>
                </TableView>

            </children>
        </VBox>
    </center>

    <!-- ── BOTTOM: Actions + status + Guest tag ── -->
    <bottom>
        <VBox style="-fx-background-color: #ecf0f1; -fx-border-color: #bdc3c7; -fx-border-width: 1 0 0 0;">
            <padding>
                <Insets bottom="14.0" left="24.0" right="24.0" top="14.0" />
            </padding>
            <children>

                <Label fx:id="statusLabel" alignment="CENTER" maxWidth="1.7976931348623157E308" styleClass="status-label" text="" />

                <Region prefHeight="8.0" />

                <HBox alignment="CENTER" spacing="16.0">
                    <children>
                        <Button onAction="#handleBack" prefHeight="38.0" prefWidth="180.0" styleClass="btn-secondary" text="← Back" />
                        <Button onAction="#handleConfirmCancel" prefHeight="38.0" prefWidth="220.0" styleClass="btn-main" text="Confirm Cancellation" />
                    </children>
                </HBox>

                <Region prefHeight="6.0" />

                <!-- Guest tag bottom-right -->
                <HBox alignment="CENTER_RIGHT">
                    <children>
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;" text="Logged in as: " />
                        <Label fx:id="guestTagLabel" style="-fx-font-size: 11px; -fx-text-fill: #e06d67; -fx-font-weight: bold;" text="—" />
                    </children>
                </HBox>

            </children>
        </VBox>
    </bottom>

</BorderPane>
