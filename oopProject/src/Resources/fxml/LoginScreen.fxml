<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import java.net.URL?>

<AnchorPane prefHeight="500.0" prefWidth="500.0"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.hotel.controllers.LoginController">

   <stylesheets>
      <URL value="@styles.css"/>
   </stylesheets>

   <children>
      <AnchorPane layoutX="-2.0" layoutY="-2.0" prefHeight="500.0" prefWidth="500.0">
         <children>

            <!-- Title -->
            <Label layoutX="150.0" layoutY="40.0" text="Hotel Login" styleClass="title-label"/>

            <!-- Username -->
            <Label text="Username" styleClass="field-label" layoutX="80.0" layoutY="110.0"/>
            <TextField fx:id="loginUsernameField" promptText="Enter username"
                       layoutX="80.0" layoutY="130.0" styleClass="input-field" prefWidth="300.0"/>

            <!-- Password -->
            <Label text="Password" styleClass="field-label" layoutX="80.0" layoutY="175.0"/>
            <PasswordField fx:id="loginPasswordField" promptText="Enter password"
                           layoutX="80.0" layoutY="195.0" styleClass="input-field" prefWidth="300.0"/>
            <!-- Visible password TextField (hidden by default) -->
            <TextField fx:id="loginPasswordVisible" promptText="Enter password"
                       layoutX="80.0" layoutY="195.0" styleClass="input-field"
                       prefWidth="300.0" visible="false"/>

            <!-- Show Password checkbox -->
            <CheckBox fx:id="showPasswordCheck" layoutX="80.0" layoutY="235.0"
                      text="Show Password" onAction="#handleShowPassword"/>

            <!-- Buttons -->
            <Button layoutX="80.0" layoutY="280.0" prefWidth="300.0"
                    mnemonicParsing="false" styleClass="btn-main"
                    onAction="#handleLogin" text="Login"/>
            <Button layoutX="80.0" layoutY="330.0" prefWidth="300.0"
                    mnemonicParsing="false" styleClass="btn-secondary"
                    onAction="#handleGoToRegister" text="Sign Up"/>

            <!-- Status label -->
            <Label fx:id="loginStatusLabel" layoutX="80.0" layoutY="385.0" text=""/>

         </children>
      </AnchorPane>
   </children>
</AnchorPane>
