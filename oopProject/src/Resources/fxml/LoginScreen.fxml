<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="500.0" prefWidth="500.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hotel.controllers.LoginController">

   <stylesheets>
      <URL value="@styles.css" />
   </stylesheets>

   <children>
      <AnchorPane layoutX="-2.0" layoutY="-2.0" prefHeight="500.0" prefWidth="500.0">
         <children>

            <!-- Title -->
            <Label layoutX="150.0" layoutY="40.0" styleClass="title-label" text="Hotel Login" />

            <!-- Username -->
            <Label layoutX="80.0" layoutY="110.0" styleClass="field-label" text="Username" />
            <TextField fx:id="loginUsernameField" layoutX="80.0" layoutY="130.0" prefWidth="300.0" promptText="Enter username" styleClass="input-field" />

            <!-- Password -->
            <Label layoutX="80.0" layoutY="175.0" styleClass="field-label" text="Password" />
            <PasswordField fx:id="loginPasswordField" layoutX="80.0" layoutY="195.0" prefWidth="300.0" promptText="Enter password" styleClass="input-field" />
            <!-- Visible password TextField (hidden by default) -->
            <TextField fx:id="loginPasswordVisible" layoutX="80.0" layoutY="195.0" prefWidth="300.0" promptText="Enter password" styleClass="input-field" visible="false" />

            <!-- Show Password checkbox -->
            <CheckBox fx:id="showPasswordCheck" layoutX="80.0" layoutY="235.0" onAction="#handleShowPassword" text="Show Password" />

            <!-- Buttons -->
            <Button layoutX="80.0" layoutY="280.0" mnemonicParsing="false" onAction="#handleLogin" prefWidth="300.0" styleClass="btn-main" text="Login" />
            <Button layoutX="80.0" layoutY="330.0" mnemonicParsing="false" onAction="#handleGoToRegister" prefWidth="300.0" styleClass="btn-secondary" text="Sign Up" />

            <!-- Status label -->
            <Label fx:id="loginStatusLabel" layoutX="80.0" layoutY="385.0" text="" />
            <Button layoutX="196.0" layoutY="381.0" mnemonicParsing="false" onAction="#handleBack" prefHeight="25.0" prefWidth="67.0" styleClass="btn-secondary" stylesheets="@styles.css" text="Back" />

         </children>
      </AnchorPane>
   </children>
</AnchorPane>
