<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import java.net.URL?>

<AnchorPane prefHeight="550.0" prefWidth="700.0"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.hotel.controllers.RegisterController">

   <stylesheets>
      <URL value="@styles.css"/>
   </stylesheets>

   <children>
      <AnchorPane layoutX="0.0" layoutY="0.0" prefHeight="550.0" prefWidth="700.0">
         <children>

            <!-- Title -->
            <Label text="Create Account" styleClass="title-label"
                   layoutX="250.0" layoutY="20.0"/>

            <!-- Username label + field -->
            <Label text="Username" styleClass="field-label"
                   layoutX="30.0" layoutY="75.0"/>
            <TextField fx:id="regUsernameField" promptText="Enter username"
                       styleClass="input-field"
                       layoutX="30.0" layoutY="95.0" prefWidth="640.0"/>

            <!-- Password labels -->
            <Label text="Password" styleClass="field-label"
                   layoutX="30.0" layoutY="140.0"/>
            <Label text="Confirm Password" styleClass="field-label"
                   layoutX="355.0" layoutY="140.0"/>

            <!-- Password fields -->
            <PasswordField fx:id="regPasswordField" promptText="Min 6 characters"
                           styleClass="input-field"
                           layoutX="30.0" layoutY="160.0" prefWidth="305.0"/>
            <TextField fx:id="regPasswordVisible" promptText="Min 6 characters"
                       styleClass="input-field" visible="false"
                       layoutX="30.0" layoutY="160.0" prefWidth="305.0"/>

            <PasswordField fx:id="regConfirmPasswordField" promptText="Repeat password"
                           styleClass="input-field"
                           layoutX="345.0" layoutY="160.0" prefWidth="325.0"/>
            <TextField fx:id="regConfirmPasswordVisible" promptText="Repeat password"
                       styleClass="input-field" visible="false"
                       layoutX="345.0" layoutY="160.0" prefWidth="325.0"/>

            <!-- Show Password checkbox -->
            <CheckBox fx:id="showPasswordCheck" layoutX="30.0" layoutY="205.0"
                      text="Show Password" onAction="#handleShowPassword"/>

            <!-- Gender labels -->
            <Label text="Date of Birth" styleClass="field-label"
                   layoutX="30.0" layoutY="230.0"/>
            <Label text="Gender" styleClass="field-label"
                   layoutX="355.0" layoutY="230.0"/>

            <!-- DOB + Gender fields -->
            <DatePicker fx:id="regDobPicker"
                        layoutX="30.0" layoutY="250.0" prefWidth="305.0"/>
            <ComboBox fx:id="regGenderCombo" promptText="Select gender"
                      layoutX="345.0" layoutY="250.0" prefWidth="325.0"/>

            <!-- Address + Balance labels -->
            <Label text="Address" styleClass="field-label"
                   layoutX="30.0" layoutY="295.0"/>
            <Label text="Initial Balance ($)" styleClass="field-label"
                   layoutX="355.0" layoutY="295.0"/>

            <!-- Address + Balance fields -->
            <TextField fx:id="regAddressField" promptText="Enter address"
                       styleClass="input-field"
                       layoutX="30.0" layoutY="315.0" prefWidth="305.0"/>
            <TextField fx:id="regBalanceField" promptText="e.g. 1000.0"
                       styleClass="input-field"
                       layoutX="345.0" layoutY="315.0" prefWidth="325.0"/>

            <!-- Status -->
            <Label fx:id="regStatusLabel" text="" styleClass="status-label"
                   layoutX="30.0" layoutY="365.0"/>

            <!-- Buttons -->
            <Button text="Register" styleClass="btn-main"
                    onAction="#handleRegister"
                    layoutX="30.0" layoutY="420.0" prefWidth="305.0"/>
            <Button text="← Back to Login" styleClass="btn-secondary"
                    onAction="#handleBackToLogin"
                    layoutX="345.0" layoutY="420.0" prefWidth="325.0"/>

         </children>
      </AnchorPane>
   </children>
</AnchorPane>
