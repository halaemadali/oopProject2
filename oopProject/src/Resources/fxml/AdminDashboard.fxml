<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="650.0" prefWidth="900.0" style="-fx-background-color: #f0f4f8;" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hotel.controllers.AdminDashboardController">

    <top>
        <VBox style="-fx-background-color: #2c2c2c;" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="16.0" left="24.0" right="24.0" top="16.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <children>
                        <VBox spacing="2.0">
                            <children>
                                <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;" text="🛡️  Admin Dashboard" />
                                <Label style="-fx-font-size: 12px; -fx-text-fill: #aaaaaa;" text="Hotel Management System | Admin Panel" />
                            </children>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS" />

                        <VBox alignment="CENTER_RIGHT" spacing="2.0">
                            <children>
                                <Label style="-fx-font-size: 11px; -fx-text-fill: #aaaaaa;" text="Logged in as:" />
                                <Label fx:id="lblAdminName" style="-fx-font-size: 14px; -fx-text-fill: #e06d67; -fx-font-weight: bold;" text="Administrator" />
                            </children>
                        </VBox>

                        <Button onAction="#handleLogout" prefHeight="34.0" styleClass="btn-secondary" text="Logout" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>

    <left>
        <VBox prefWidth="230.0" spacing="10.0" style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 0 1 0 0;">
            <padding>
                <Insets bottom="24.0" left="16.0" right="16.0" top="24.0" />
            </padding>
            <children>
                <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #aaaaaa;" text="ADMINISTRATIVE ACTIONS" />
                <Separator />

                <Button maxWidth="Infinity" onAction="#handleAddRoom" prefHeight="40.0" styleClass="btn-main" text="🏨  Add Room" />

                <Button maxWidth="Infinity" onAction="#handleAddRoomType" prefHeight="40.0" styleClass="btn-secondary" text="🏷️  Add Room Type" />

                <Separator />

                <Button maxWidth="Infinity" onAction="#handleAddReceptionist" prefHeight="40.0" styleClass="btn-main" text="👥  Add Receptionist" />

                <Button maxWidth="Infinity" onAction="#handleAddAmenity" prefHeight="40.0" styleClass="btn-secondary" text="✨  Add Amenity" />

                <Region VBox.vgrow="ALWAYS" />

                <Separator />
                <Label alignment="CENTER" maxWidth="Infinity" style="-fx-text-fill: #cccccc; -fx-font-size: 11px;" text="System Version 1.0" />
            </children>
        </VBox>
    </left>

    <center>
        <VBox alignment="CENTER" spacing="15.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets all="40.0" />
            </padding>
            <children>
                <Label style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Admin Control Center" />
                <Label style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;" text="Select an option from the left sidebar to manage the system." textAlignment="CENTER" wrapText="true" />

                <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="30.0" style="-fx-opacity: 0.3;">
                    <children>
                        <Label style="-fx-font-size: 50px;" text="🛠️" />
                        <Label style="-fx-font-size: 50px;" text="⚙️" />
                        <Label style="-fx-font-size: 50px;" text="📊" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>

</BorderPane>